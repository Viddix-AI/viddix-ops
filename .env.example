# Copy to .env.local and fill in real values to enable Supabase.
# When unset, Viddix Ops runs entirely from localStorage (demo mode).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key used by /api/webhooks/cal to insert events server-side.
# Keep secret — never expose to the browser. Optional: if unset, the webhook
# falls back to the anon key (RLS must allow inserts for that to work).
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret configured in Cal.com → Settings → Developer → Webhooks.
# The webhook handler validates the X-Cal-Signature-256 HMAC against this.
# When unset, signature verification is skipped — only acceptable in dev.
CAL_WEBHOOK_SECRET=
